{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "photo-archiver",
  "version": "0.1.1",
  "identifier": "ch.orellbuehler.photoarchiver",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Photo Archiver",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Photography",
    "copyright": "© Orell Bühler",
    "publisher": "Orell Bühler",
    "shortDescription": "Restore and organize scanned photos",
    "longDescription": "A native desktop app for restoring scanned old photos (crop, deskew, colour, dust, scan-line removal, AI enhancement) and organizing them into folders. Works on local and mounted drives.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
